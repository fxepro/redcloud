# Laravel API base URL (Railway). Leave empty to use bundled local seed content.
NEXT_PUBLIC_API_URL=
# Public site URL (used for metadata / sitemap)
NEXT_PUBLIC_SITE_URL=https://redcloudsystems.com
# Cloudflare Turnstile site key (spam protection on forms)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# Google reviews (server-side). Both required to show live Google reviews.
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
