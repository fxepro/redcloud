# Laravel API base URL (Railway). Leave empty to use bundled local seed content
# and the built-in /api/forms handler for submissions.
NEXT_PUBLIC_API_URL=
# Public site URL (used for metadata / sitemap)
NEXT_PUBLIC_SITE_URL=https://redcloudsystems.com
# Cloudflare Turnstile site key (spam protection on forms)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# Form delivery via Web3Forms (https://web3forms.com — free, no credit card).
# Sign up with your email to get an access key; add it in Netlify env vars.
WEB3FORMS_ACCESS_KEY=
# Google reviews (server-side). Both required to show live Google reviews.
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
